{
  "name": "@maskor/api",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run ./src/index.ts",
    "dev": "bun --watch run ./src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "generate-openapi": "bun run ./src/scripts/generate-openapi.ts",
    "verify:openapi": "bun run ./src/scripts/generate-openapi.ts /tmp/maskor-openapi-check.json && git diff --no-index --exit-code ../frontend/src/api/openapi.json /tmp/maskor-openapi-check.json"
  },
  "devDependencies": {
    "@maskor/test-fixtures": "workspace:*",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@maskor/exporter": "workspace:*",
    "@maskor/importer": "workspace:*",
    "@maskor/sequencer": "workspace:*",
    "@maskor/shared": "workspace:*",
    "@maskor/storage": "workspace:*",
    "hono": "^4.7.10",
    "trash": "^10.1.1",
    "zod": "^4.3.6"
  }
}
