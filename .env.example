# Maskor — local development configuration.
#
# Copy to `.env` (gitignored) and adjust. A `.env` is OPTIONAL — the defaults
# below are baked into the code, so the stack runs with no `.env` at all.
#
# This single file is the one place to configure ports and env. It is read by
# BOTH sides, so they can never drift:
#   - the API loads it (the package scripts pass `--env-file=<repo>/.env`)
#   - the frontend dev server loads it (Vite `envDir` points at the repo root)
#
# Because the frontend proxy targets the same MASKOR_API_PORT the API binds,
# changing the port here updates both at once.

# Port the API server binds to, and the port the frontend dev-server proxy
# forwards `/api/*` requests to.
MASKOR_API_PORT=3001

# Host the frontend dev-server proxy targets for the API. The API and frontend
# run on the same machine in dev, so this is localhost.
MASKOR_API_HOST=127.0.0.1

# API log verbosity: fatal | error | warn | info | debug | trace.
LOG_LEVEL=info

# Dev-only DB auto-reset on schema drift. When set to `1`/`true`, a vault/registry
# DB whose schema fingerprint no longer matches the code's migration set is dropped
# and recreated clean on open (then repopulated from the vault by the startup
# rebuild) — instead of forcing the manual "delete vault.db + restart" loop after a
# schema change.
#
# The API `dev` script (packages/api: `bun run dev`) already sets this to `1`, so
# `bun run dev` auto-resets on a migration change with no setup. It is NEVER set by
# the packaged `start` script, so a production run never resets. You only need the
# line below to ENABLE it for a non-`dev` run, or to DISABLE it during `dev` by
# overriding the dev-script default (set it to `0`). Note: an inline env var in the
# dev script takes precedence over this file, so to disable during `dev` you must
# edit the dev script, not just this file.
#
# Resetting discards DB-only state that can't be re-derived from the vault
# (`fragment_stats` telemetry, dismissed UUID_COLLISION warnings, the project
# registry) — acceptable in greenfield dev, which is why it is dev-scoped.
# MASKOR_DB_AUTO_RESET=1
